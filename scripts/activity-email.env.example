# Copy to scripts/activity-email.env on beacon (do not commit secrets).

# PostgREST (Kong on the same host)
SUPABASE_URL=http://127.0.0.1:8000
SERVICE_ROLE_KEY=your-service-role-jwt

# Same SMTP as GoTrue OTP
SMTP_HOST=smtp.openxchange.eu
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=a@exled.app
SMTP_PASSWORD=your-password
SMTP_FROM=ExLed <a@exled.app>

EXLED_APP_URL=https://be.exled.app
BATCH_LIMIT=20
